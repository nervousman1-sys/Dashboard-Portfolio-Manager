# ── Finextium Agent Scanner — environment ──
# Copy this file to ".env" (same folder) and fill in the two SECRET values below.

# Supabase — project URL is already correct for your project.
SUPABASE_URL=https://jdebxhxaiwbtgweruznd.supabase.co
# SECRET — Supabase Dashboard → Project Settings → API → "service_role" key (NOT the anon key).
# The agent needs it to write into catalyst_cards (it bypasses RLS). Never expose it in the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini — AI Studio key (https://aistudio.google.com/app/apikey). Grounding/Search enabled.
GEMINI_API_KEY=

# ── Tuning (optional — sensible defaults) ──
GEMINI_MODEL=gemini-2.5-flash
SCAN_INTERVAL_HOURS=4
DEDUP_DAYS=14
