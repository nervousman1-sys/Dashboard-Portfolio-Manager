# ── Finextium Agent Scanner — environment ──
# Copy to ".env" and fill the values. The DB write path needs NO service_role key — the agent
# writes through the secure insert_catalyst_card() RPC using the public anon key + a shared secret.

SUPABASE_URL=https://jdebxhxaiwbtgweruznd.supabase.co

# Public anon key (Supabase → Settings → API → anon/public). Safe to keep here.
SUPABASE_ANON_KEY=

# Shared secret that the insert_catalyst_card() RPC checks before writing. Must EXACTLY match the
# value baked into that function in the database. Keep it private (do NOT commit a filled .env).
AGENT_WRITE_SECRET=

# Google Gemini key (AI Studio). Grounding/Search enabled.
GEMINI_API_KEY=

# Optional: paste a service_role key here to use a direct insert instead of the RPC.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Tuning (optional) ──
GEMINI_MODEL=gemini-2.5-flash
SCAN_INTERVAL_HOURS=4
DEDUP_DAYS=14

# ── Reports agent (reports-agent.js) — 24/7 sweep of every company's latest report → company_reports ──
# Uses the public site to read the ticker universe and Yahoo for the financials (no FMP quota burn).
SITE_URL=https://finextium-dashboard.vercel.app
REPORTS_BATCH=5             # companies fetched concurrently per wave
REPORTS_GAP_MS=1100         # pause between waves (gentle on Yahoo — raise if rate-limited)
REPORTS_REST_MIN=8          # rest between full universe sweeps (lower = fresher, more load)
REPORTS_HEARTBEAT_EVERY=40  # write an agent_status heartbeat every N companies

# Market-cap gate + listed validation (Finnhub profile2 — has a working fallback key built in):
FINNHUB_API_KEY=
MIN_MARKET_CAP_B=1
