# ── Finextium Agent Scanner — environment ──
# Copy to ".env" and fill the values. The DB write path needs NO service_role key — the agent
# writes through the secure insert_catalyst_card() RPC using the public anon key + a shared secret.

SUPABASE_URL=https://jdebxhxaiwbtgweruznd.supabase.co

# Public anon key (Supabase → Settings → API → anon/public). Safe to keep here.
SUPABASE_ANON_KEY=

# Shared secret that the insert_catalyst_card() RPC checks before writing. Must EXACTLY match the
# value baked into that function in the database. Keep it private (do NOT commit a filled .env).
AGENT_WRITE_SECRET=

# Google Gemini key (AI Studio). Grounding/Search enabled.
GEMINI_API_KEY=

# Optional: paste a service_role key here to use a direct insert instead of the RPC.
# SUPABASE_SERVICE_ROLE_KEY=

# ── Tuning (optional) ──
GEMINI_MODEL=gemini-2.5-flash
SCAN_INTERVAL_HOURS=4
DEDUP_DAYS=14
